new file mode 100644
index 0000000..fd2dd7f
--- /dev/null
+++ b/src/video/safaos/SDL_safaosvideo.c
@@ -0,0 +1,161 @@
+
+/*
+  Simple DirectMedia Layer
+  Copyright (C) 1997-2026 Sam Lantinga <slouken@libsdl.org>
+
+  This software is provided 'as-is', without any express or implied
+  warranty.  In no event will the authors be held liable for any damages
+  arising from the use of this software.
+
+  Permission is granted to anyone to use this software for any purpose,
+  including commercial applications, and to alter it and redistribute it
+  freely, subject to the following restrictions:
+
+  1. The origin of this software must not be misrepresented; you must not
+     claim that you wrote the original software. If you use this software
+     in a product, an acknowledgment in the product documentation would be
+     appreciated but is not required.
+  2. Altered source versions must be plainly marked as such, and must not be
+     misrepresented as being the original software.
+  3. This notice may not be removed or altered from any source distribution.
+*/
+#include "../../SDL_internal.h"
+#include "SDL_pixels.h"
+#include <stdint.h>
+
+#if SDL_VIDEO_DRIVER_SAFAOS
+
+#include "SDL_video.h"
+#include "SDL_mouse.h"
+#include "../SDL_sysvideo.h"
+#include "../SDL_pixels_c.h"
+#include "../../events/SDL_events_c.h"
+
+#include "SDL_hints.h"
+
+#define SAFAVID_DRIVER_NAME       "safaos"
+
+typedef void SAFAVID_App;
+
+void SAFAVID_init_app(SAFAVID_App **app);
+void SAFAVID_destroy_app(SAFAVID_App *app);
+
+void SAFA_video_bounds(uint32_t *w, uint32_t *h);
+uint8_t SAFA_handle_events(SAFAVID_App *app, SDL_Window* windows);
+
+uint8_t SAFA_create_SDL_window(SAFAVID_App *app, SDL_Window* window);
+void SAFA_destroy_SDL_window(SAFAVID_App *app, SDL_Window* window);
+
+
+int SAFA_CreateWindow(_THIS, SDL_Window* window) {
+    if (!SAFA_create_SDL_window(_this->driverdata, window)) {
+        return -1;
+    }
+    return 0;
+}
+
+static void SAFA_DestroyWindow(_THIS, SDL_Window* window) {
+    SAFA_destroy_SDL_window(_this->driverdata, window);
+}
+
+
+
+static void SAFA_PumpEvents(_THIS)
+{
+    SAFA_handle_events(_this->driverdata, _this->windows);
+}
+
+int SAFA_VideoInit(_THIS)
+{
+    uint32_t w;
+    uint32_t h;
+    SDL_DisplayMode mode;
+    SDL_zero(mode);
+    SAFA_video_bounds(&w, &h);
+
+
+    mode.format = SDL_PIXELFORMAT_BGRA8888;
+    mode.w = w;
+    mode.h = h;
+    mode.refresh_rate = 60;
+    mode.driverdata = NULL;
+    if (SDL_AddBasicVideoDisplay(&mode) < 0) {
+        return -1;
+    }
+
+    SDL_AddDisplayMode(&_this->displays[0], &mode);
+
+    SAFAVID_init_app(&_this->driverdata);
+    return 0;
+}
+
+
+static void SAFA_DeleteDevice(SDL_VideoDevice *device)
+{
+    SDL_free(device);
+}
+
+static void SAFA_VideoQuit(_THIS)
+{
+    SAFAVID_destroy_app(_this->driverdata);
+}
+
+void SAFA_DestroyWindowFramebuffer(_THIS, SDL_Window *window)
+{
+}
+
+void SAFA_setup_window_pixels(SAFAVID_App *app, SDL_Window *window, void **pixels, int *pitch);
+static int SAFA_CreateWindowFramebuffer(_THIS, SDL_Window *window, Uint32 *format, void **pixels, int *pitch)
+{
+    SAFA_setup_window_pixels(_this->driverdata, window, pixels, pitch);
+    *format = SDL_PIXELFORMAT_ARGB8888;
+    return 0;
+}
+
+void SAFA_update_window_pixels(SAFAVID_App *app, SDL_Window *window, const SDL_Rect *rects, int numrects);
+static int SAFA_UpdateWindowFramebuffer(_THIS, SDL_Window *window, const SDL_Rect *rects, int numrects)
+{
+    SAFA_update_window_pixels(_this->driverdata, window, rects, numrects);
+    return 0;
+}
+
+
+int SAFAVID_set_window_title(SAFAVID_App *app, SDL_Window *window, const char *new_title);
+static void SAFA_SetWindowTitle(_THIS, SDL_Window *window) {
+    SAFAVID_set_window_title(_this->driverdata, window, window->title);
+}
+
+static SDL_VideoDevice *SAFA_CreateDevice(void)
+{
+    SDL_VideoDevice *device;
+
+    device = (SDL_VideoDevice *)SDL_calloc(1, sizeof(SDL_VideoDevice));
+    if (!device) {
+        SDL_OutOfMemory();
+        return 0;
+    }
+
+    /* Set the function pointers */
+    device->VideoInit = SAFA_VideoInit;
+    device->VideoQuit = SAFA_VideoQuit;
+    device->PumpEvents = SAFA_PumpEvents;
+
+    device->CreateSDLWindow = SAFA_CreateWindow;
+    device->DestroyWindow = SAFA_DestroyWindow;
+    device->CreateWindowFramebuffer = SAFA_CreateWindowFramebuffer;
+    device->UpdateWindowFramebuffer = SAFA_UpdateWindowFramebuffer;
+    device->DestroyWindowFramebuffer = SAFA_DestroyWindowFramebuffer;
+    device->SetWindowTitle = SAFA_SetWindowTitle;
+
+    device->free = SAFA_DeleteDevice;
+
+    return device;
+}
+
+VideoBootStrap SAFA_bootstrap = {
+    SAFAVID_DRIVER_NAME, "SDL SAFA video driver",
+    SAFA_CreateDevice,
+    NULL /* no ShowMessageBox implementation */
+};
+
+#endif
