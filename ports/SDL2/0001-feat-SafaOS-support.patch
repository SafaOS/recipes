diff --git a/CMakeLists.txt b/CMakeLists.txt
index 8e5fb1c..23b1072 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -359,7 +359,7 @@ if(EMSCRIPTEN)
   set(SDL_CPUINFO_ENABLED_BY_DEFAULT OFF)
 endif()
 
-if(VITA OR PSP OR PS2 OR N3DS)
+if(VITA OR PSP OR PS2 OR N3DS OR SAFAOS)
   set(SDL_SHARED_ENABLED_BY_DEFAULT OFF)
   set(SDL_LOADSO_ENABLED_BY_DEFAULT OFF)
 endif()
@@ -1411,7 +1411,34 @@ if(ANDROID)
   if(SDL_CLOCK_GETTIME)
     set(HAVE_CLOCK_GETTIME 1)
   endif()
+elseif(SAFAOS)
+  list(APPEND EXTRA_LIBS SafaSDL)
 
+  if(SDL_VIDEO)
+    set(SDL_VIDEO_DRIVER_SAFAOS 1)
+    file(GLOB VIDEO_SOURCES ${SDL2_SOURCE_DIR}/src/video/safaos/*.c)
+    list(APPEND SOURCE_FILES ${VIDEO_SOURCES})
+    set(HAVE_SDL_VIDEO TRUE)
+  endif()
+
+  if(SDL_AUDIO)
+    set(SDL_AUDIO_DRIVER_SAFAOS 1)
+    file(GLOB AUDIO_SOURCES ${SDL2_SOURCE_DIR}/src/audio/safaos/*.c)
+    list(APPEND SOURCE_FILES ${AUDIO_SOURCES})
+    set(HAVE_SDL_AUDIO TRUE)
+  endif()
+
+  if(SDL_TIMERS)
+    file(GLOB TIMER_SOURCES ${SDL2_SOURCE_DIR}/src/timer/safaos/*.c)
+    list(APPEND SOURCE_FILES ${TIMER_SOURCES})
+    set(HAVE_SDL_TIMERS TRUE)
+  endif()
+
+  set(SDL_PTHREADS 1)
+  set(SDL_THREADS 1)
+  CheckPTHREAD()
+
+  message_warn("HAVE_SDL_THREADS=${HAVE_SDL_THREADS}, OS=${CMAKE_SYSTEM_NAME}, HAVE_PTHREADS=${HAVE_PTHREADS}, HAVE_MALLOC=${HAVE_MALLOC}")
 elseif(EMSCRIPTEN)
   # Hide noisy warnings that intend to aid mostly during initial stages of porting a new
   # project. Uncomment at will for verbose cross-compiling -I/../ path info.
