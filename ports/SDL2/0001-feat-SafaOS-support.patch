+*/
+#include "../../SDL_internal.h"
+#include "SDL_assert.h"
+#include "SDL_error.h"
+#include "SDL_log.h"
+#include "SDL_stdinc.h"
+
+#ifdef SDL_AUDIO_DRIVER_SAFAOS
+
+/* Output audio to nowhere... */
+
+#include "SDL_audio.h"
+#include "SDL_safaosaudio.h"
+
+int SAFA_create_stream(Uint32 freq, Uint32 audio_depth, Uint8 is_floating, Uint8 is_singed, Uint16 channels, Uint32 samples, void** results);
+static int SAFAAUD_OpenDevice(_THIS, const char *devname)
+{
+
+    Uint8 is_floating;
+    Uint8 is_singed;
+    Uint32 bit_depth;
+    Uint16 channels;
+    Uint32 freq;
+    Uint32 samples;
+
+    SDL_AudioFormat og_format = _this->spec.format;
+    SDL_LogDebug(SDL_LOG_CATEGORY_AUDIO, "Requested format: %x, channels: %x\n", og_format, _this->spec.channels);
+
+    // Ensure giving in a correct format
+    if (SDL_AUDIO_ISBIGENDIAN(_this->spec.format))
+        _this->spec.format = AUDIO_F32LSB;
+
+    is_floating = SDL_AUDIO_ISFLOAT(_this->spec.format) != 0;
+    is_singed = SDL_AUDIO_ISSIGNED(_this->spec.format) != 0;
+    bit_depth = SDL_AUDIO_BITSIZE(_this->spec.format);
+    channels = 2;
+    freq = (_this->spec.freq >= 1000) ? _this->spec.freq : 44100;
+    samples = (_this->spec.samples >= 100) ? _this->spec.samples*channels : freq * channels;
+
+    if (!is_floating && !is_singed) {
+        _this->spec.format = AUDIO_F32LSB;
+        is_floating = (Uint8)SDL_TRUE;
+    }
+
+    if (is_floating) {
+        bit_depth = 32;
+        _this->spec.format = AUDIO_F32LSB;
+    }
+
+    _this->spec.channels = channels;
+    _this->spec.freq = freq;
+    _this->spec.samples = samples / channels;
+
+    if (og_format != _this->spec.format)
+        SDL_LogWarn(SDL_LOG_CATEGORY_AUDIO, "format %x != requested %x, FIXME: May be UB\n", _this->spec.format, og_format);
+    SDL_LogDebug(SDL_LOG_CATEGORY_AUDIO, "final format %x, is_floating=%d, is_singed=%d, bit_depth=%d\n", _this->spec.format, is_floating, is_singed, bit_depth);
+    if (SAFA_create_stream(freq, bit_depth, is_floating, is_singed, channels, samples, &_this->hidden) != 0) {
+        SDL_SetError("Failed to construct a valid audio format for libartemis");
+        return -1;
+    }
+
+    SDL_assert(_this->hidden && SDL_TRUE);
+    return 0;
+}
+
+void SAFA_destroy_stream(void* stream);
+static void SAFAAUD_CloseDevice(_THIS) {
+    SAFA_destroy_stream(_this->hidden);
+}
+
+Uint8* SAFAAUD_get_stream_buf(void* stream);
+static Uint8* SAFAAUD_GetDeviceBuf(_THIS) {
+    if (_this->hidden == NULL)
+        return NULL;
+    return SAFAAUD_get_stream_buf(_this->hidden);
+}
+
+Uint32 SAFAAUD_stream_sync_all(void* stream);
+
+static void SAFAAUD_PlayDevice(_THIS) {
+    SAFAAUD_stream_sync_all(_this->hidden);
+}
+
+
+static SDL_bool SAFAAUD_Init(SDL_AudioDriverImpl *impl)
+{
+    /* Set the function pointers */
+    impl->OpenDevice = SAFAAUD_OpenDevice;
+    impl->CloseDevice = SAFAAUD_CloseDevice;
+
+    impl->GetDeviceBuf = SAFAAUD_GetDeviceBuf;
+    impl->PlayDevice = SAFAAUD_PlayDevice;
+
+    impl->OnlyHasDefaultOutputDevice = SDL_TRUE;
+    impl->HasCaptureSupport = SDL_FALSE;
+    impl->ProvidesOwnCallbackThread = SDL_FALSE;
+    impl->SupportsNonPow2Samples = SDL_TRUE;
+
+    return SDL_TRUE; /* this audio target is available. */
+}
+
+AudioBootStrap SAFAAUD_bootstrap = {
+    "safaos", "SDL SafaOS audio driver", SAFAAUD_Init, SDL_FALSE
+};
+
+#endif
+
