--- /dev/null
+++ b/sdl-safaos/build.sh
@@ -0,0 +1,17 @@
+# Builds the libc library
+# output is in the `out` directory
+
+
+target=$1
+if [ -z "$target" ]; then
+    echo "Usage: $0 [arch=x86_64|aarch64]"
+    exit 1
+fi
+
+set -euo pipefail
+sasdl=$(cargo +"$target-unknown-safaos" rustc --crate-type=staticlib --target "$target-unknown-safaos" --release --message-format=json-render-diagnostics -- -C force-unwind-tables | jq -r 'select(.reason == "compiler-artifact" and (.target.kind | index("staticlib"))) | .filenames[] | select(endswith(".a"))')
+
+
+rm -rf out || true
+mkdir -p out
+cp $sasdl "out/libSafaSDL.a"
