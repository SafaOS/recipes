+++ b/sdl-safaos/src/video.rs
@@ -0,0 +1,393 @@
+use std::{
+    ffi::{CStr, c_char},
+    os::raw::c_int,
+    time::Duration,
+};
+
+use libgems::{AppEnv, WindowBuilder};
+use libopal::{
+    DequeuedEvents, WindowEvent,
+    defs::{HeldMouseButtons, KeyModifiers, WindowID},
+    event::{KeyCode, KeyEventKind},
+};
+
+use crate::video::defs::{SDLApp, SDLData, SDLRect, SDLWindow};
+
+mod sdl_scancode;
+use sdl_scancode::*;
+mod defs;
+
+#[unsafe(no_mangle)]
+pub extern "C" fn SAFAVID_init_app(app: *mut *mut SDLApp) {
+    unsafe { *app = Box::into_raw(Box::new(SDLApp::new(SDLData).with_env(AppEnv::sys_theme()))) }
+}
+
+#[unsafe(no_mangle)]
+pub extern "C" fn SAFAVID_destroy_app(app: *mut SDLApp) {
+    drop(unsafe { Box::from_raw(app) });
+}
+const SDL_BUTTON_LEFT: u8 = 1;
+const SDL_BUTTON_MIDDLE: u8 = 2;
+const SDL_BUTTON_RIGHT: u8 = 3;
+#[inline]
+fn safaos_keycode_to_sdl_scancode(code: u16) -> SDLScancode {
+    // Try to map the incoming KeyCode numeric value to the libopal KeyCode enum
+    let key = match KeyCode::try_from(code) {
+        Ok(k) => k,
+        Err(_) => return SDL_SCANCODE_UNKNOWN,
+    };
+
+    match key {
+        KeyCode::Null => SDL_SCANCODE_UNKNOWN,
+
+        // Function keys
+        KeyCode::F1 => SDL_SCANCODE_F1,
+        KeyCode::F2 => SDL_SCANCODE_F2,
+        KeyCode::F3 => SDL_SCANCODE_F3,
+        KeyCode::F4 => SDL_SCANCODE_F4,
+        KeyCode::F5 => SDL_SCANCODE_F5,
+        KeyCode::F6 => SDL_SCANCODE_F6,
+        KeyCode::F7 => SDL_SCANCODE_F7,
+        KeyCode::F8 => SDL_SCANCODE_F8,
+        KeyCode::F9 => SDL_SCANCODE_F9,
+        KeyCode::F10 => SDL_SCANCODE_F10,
+        KeyCode::F11 => SDL_SCANCODE_F11,
+        KeyCode::F12 => SDL_SCANCODE_F12,
+        KeyCode::PrintScr => SDL_SCANCODE_PRINTSCREEN,
+
+        // Escape / digits / punctuation
+        KeyCode::Esc => SDL_SCANCODE_ESCAPE,
+        KeyCode::Key1 => SDL_SCANCODE_1,
+        KeyCode::Key2 => SDL_SCANCODE_2,
+        KeyCode::Key3 => SDL_SCANCODE_3,
+        KeyCode::Key4 => SDL_SCANCODE_4,
+        KeyCode::Key5 => SDL_SCANCODE_5,
+        KeyCode::Key6 => SDL_SCANCODE_6,
+        KeyCode::Key7 => SDL_SCANCODE_7,
+        KeyCode::Key8 => SDL_SCANCODE_8,
+        KeyCode::Key9 => SDL_SCANCODE_9,
+        KeyCode::Key0 => SDL_SCANCODE_0,
+        KeyCode::Minus => SDL_SCANCODE_MINUS,
+        KeyCode::Equals => SDL_SCANCODE_EQUALS,
+        KeyCode::Backspace => SDL_SCANCODE_BACKSPACE,
+
+        // Q-P row
+        KeyCode::KeyQ => SDL_SCANCODE_Q,
+        KeyCode::KeyW => SDL_SCANCODE_W,
+        KeyCode::KeyE => SDL_SCANCODE_E,
+        KeyCode::KeyR => SDL_SCANCODE_R,
+        KeyCode::KeyT => SDL_SCANCODE_T,
+        KeyCode::KeyY => SDL_SCANCODE_Y,
+        KeyCode::KeyU => SDL_SCANCODE_U,
+        KeyCode::KeyI => SDL_SCANCODE_I,
+        KeyCode::KeyO => SDL_SCANCODE_O,
+        KeyCode::KeyP => SDL_SCANCODE_P,
+        KeyCode::LeftBrace => SDL_SCANCODE_LEFTBRACKET,
+        KeyCode::RightBrace => SDL_SCANCODE_RIGHTBRACKET,
+        KeyCode::BackSlash => SDL_SCANCODE_BACKSLASH,
+
+        // A-L row
+        KeyCode::KeyA => SDL_SCANCODE_A,
+        KeyCode::KeyS => SDL_SCANCODE_S,
+        KeyCode::KeyD => SDL_SCANCODE_D,
+        KeyCode::KeyF => SDL_SCANCODE_F,
+        KeyCode::KeyG => SDL_SCANCODE_G,
+        KeyCode::KeyH => SDL_SCANCODE_H,
+        KeyCode::KeyJ => SDL_SCANCODE_J,
+        KeyCode::KeyK => SDL_SCANCODE_K,
+        KeyCode::KeyL => SDL_SCANCODE_L,
+        KeyCode::Semicolon => SDL_SCANCODE_SEMICOLON,
+        KeyCode::DoubleQuote => SDL_SCANCODE_APOSTROPHE,
+        KeyCode::Return => SDL_SCANCODE_RETURN,
+
+        // Z-M row
+        KeyCode::KeyZ => SDL_SCANCODE_Z,
+        KeyCode::KeyX => SDL_SCANCODE_X,
+        KeyCode::KeyC => SDL_SCANCODE_C,
+        KeyCode::KeyV => SDL_SCANCODE_V,
+        KeyCode::KeyB => SDL_SCANCODE_B,
+        KeyCode::KeyN => SDL_SCANCODE_N,
+        KeyCode::KeyM => SDL_SCANCODE_M,
+        KeyCode::BackQuote => SDL_SCANCODE_GRAVE,
+        KeyCode::Comma => SDL_SCANCODE_COMMA,
+        KeyCode::Dot => SDL_SCANCODE_PERIOD,
+        KeyCode::Slash => SDL_SCANCODE_SLASH,
+
+        // Modifiers / whitespace / navigation
+        KeyCode::Tab => SDL_SCANCODE_TAB,
+        KeyCode::CapsLock => SDL_SCANCODE_CAPSLOCK,
+        KeyCode::Ctrl => SDL_SCANCODE_LCTRL,
+        KeyCode::Shift => SDL_SCANCODE_LSHIFT,
+        KeyCode::Alt => SDL_SCANCODE_LALT,
+        KeyCode::Super => SDL_SCANCODE_LGUI,
+        KeyCode::Space => SDL_SCANCODE_SPACE,
+        KeyCode::Up => SDL_SCANCODE_UP,
+        KeyCode::Down => SDL_SCANCODE_DOWN,
+        KeyCode::Left => SDL_SCANCODE_LEFT,
+        KeyCode::Right => SDL_SCANCODE_RIGHT,
+
+        KeyCode::PageUp => SDL_SCANCODE_PAGEUP,
+        KeyCode::PageDown => SDL_SCANCODE_PAGEDOWN,
+        KeyCode::Insert => SDL_SCANCODE_INSERT,
+        KeyCode::Delete => SDL_SCANCODE_DELETE,
+        KeyCode::Home => SDL_SCANCODE_HOME,
+        KeyCode::End => SDL_SCANCODE_END,
+
+        KeyCode::LastKey => SDL_SCANCODE_UNKNOWN,
+    }
+}
+
+#[inline(always)]
+fn handle_events<I: Iterator<Item = (WindowID, *mut SDLWindow)> + Clone>(
+    windows: I,
+    events: DequeuedEvents,
+    key_press: impl Fn(*mut SDLWindow, bool, KeyCode, KeyModifiers),
+    mouse_move: impl Fn(*mut SDLWindow, i32, i32),
+    mouse_leave: impl Fn(*mut SDLWindow),
+    mouse_btns: impl Fn(*mut SDLWindow, HeldMouseButtons, bool),
+    focus_change: impl Fn(*mut SDLWindow, bool),
+) -> bool {
+    let mut handled_any = false;
+    for event in events.into_iter() {
+        for (window, sdl_window) in windows.clone() {
+            if window == event.receiver() {
+                handled_any = true;
+                match event.event() {
+                    WindowEvent::Key(e) => {
+                        let pressed = e.kind == KeyEventKind::Press;
+                        let modifiers = e.modifiers;
+                        (key_press)(sdl_window, pressed, e.code, modifiers);
+                    }
+                    WindowEvent::MouseEnter(m) => {
+                        let x = m.x() as i32;
+                        let y = m.y() as i32;
+
+                        (mouse_move)(sdl_window, x, y);
+                    }
+                    WindowEvent::MouseLeave(_m) => {
+                        (mouse_leave)(sdl_window);
+                    }
+                    WindowEvent::MouseChange(m) => {
+                        let x = m.x() as i32;
+                        let y = m.y() as i32;
+                        (mouse_move)(sdl_window, x, y);
+                        (mouse_btns)(sdl_window, m.held_buttons(), m.buttons_changed());
+                    }
+                    WindowEvent::WindowFocusChanged(f) => {
+                        (focus_change)(sdl_window, f.is_focused());
+                    }
+                    _ => {}
+                }
+            }
+        }
+    }
+
+    handled_any
+}
+
+unsafe extern "C" {
+    fn SDL_SendKeyboardKey(state: u8, scancode: SDLScancode) -> c_int;
+    fn SDL_SendMouseMotion(
+        window: *mut SDLWindow,
+        mouse_id: c_int,
+        relative: c_int,
+        x: i32,
+        y: i32,
+    ) -> c_int;
+    fn SDL_SendMouseButton(window: *mut SDLWindow, mouse_id: c_int, state: u8, button: u8)
+    -> c_int;
+    fn SDL_SetKeyboardFocus(window: *mut SDLWindow) -> c_int;
+}
+
+#[derive(Clone, Copy)]
+struct SDLWindowIter {
+    current: *mut SDLWindow,
+}
+
+impl Iterator for SDLWindowIter {
+    type Item = *mut SDLWindow;
+
+    fn next(&mut self) -> Option<Self::Item> {
+        if self.current.is_null() {
+            None
+        } else {
+            let item = self.current;
+            self.current = unsafe { (*self.current).next };
+            Some(item)
+        }
+    }
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_handle_events(app: *mut SDLApp, windows: *mut SDLWindow, timeout: u64) -> bool {
+    let app = unsafe { &mut *app };
+    let timeout_ms = Duration::from_millis(timeout as u64);
+    let events = if timeout != 0 {
+        app.try_wait_for_events_timeout(Some(timeout_ms))
+    } else {
+        app.try_wait_for_events(false)
+    };
+
+    let Some(events) = events else {
+        return false;
+    };
+    let window_iter = SDLWindowIter { current: windows }.map(|w| (unsafe { &*w }.real_win_id(), w));
+
+    handle_events::<_>(
+        window_iter,
+        events,
+        |_, pressed, key, _| {
+            let state = if pressed { 1 } else { 0 };
+            unsafe { SDL_SendKeyboardKey(state, safaos_keycode_to_sdl_scancode(key as u16)) };
+        },
+        |w, x, y| {
+            unsafe { SDL_SendMouseMotion(w, 0, 0, x, y) };
+        },
+        |w| {
+            unsafe { SDL_SendMouseMotion(w, 0, 0, -1, -1) };
+        },
+        |w, state, _button| {
+            let mid_clicked = state.contains(HeldMouseButtons::MIDDLE);
+            let left_clicked = state.contains(HeldMouseButtons::LEFT);
+            let right_clicked = state.contains(HeldMouseButtons::RIGHT);
+
+            unsafe {
+                SDL_SendMouseButton(w, 0, if mid_clicked { 1 } else { 0 }, SDL_BUTTON_MIDDLE)
+            };
+            unsafe { SDL_SendMouseButton(w, 0, if left_clicked { 1 } else { 0 }, SDL_BUTTON_LEFT) };
+            unsafe {
+                SDL_SendMouseButton(w, 0, if right_clicked { 1 } else { 0 }, SDL_BUTTON_RIGHT)
+            };
+        },
+        |w, focused| {
+            unsafe { SDL_SetKeyboardFocus(if focused { w } else { std::ptr::null_mut() }) };
+        },
+    )
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_video_bounds(w: &mut u32, h: &mut u32) {
+    let (v_w, v_h) = libopal::get_screen_dimensions();
+    *w = v_w;
+    *h = v_h;
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFAVID_set_window_title(
+    app: *mut SDLApp,
+    sdl_window: *mut SDLWindow,
+    new_title: *const c_char,
+) -> c_int {
+    let sdl_window = unsafe { &mut *sdl_window };
+    let app = unsafe { &mut *app };
+
+    let title = if new_title.is_null() {
+        None
+    } else {
+        Some(unsafe { CStr::from_ptr(sdl_window.title) })
+    };
+
+    app.with_window_mut(sdl_window.real_win_id(), |window, data| {
+        if let Some(title) = title.and_then(|t| t.to_str().ok()) {
+            eprintln!("SAFAVID_set_window_title: `{title}`");
+            window.set_title(title, data);
+            0
+        } else {
+            eprintln!("SAFAVID_set_window_title: [[EMPTY]]");
+            window.set_title(" ", data);
+            -1
+        }
+    })
+    .expect("BAD SDL window")
+}
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_create_SDL_window(app: *mut SDLApp, sdl_window: *mut SDLWindow) -> bool {
+    let sdl_window = unsafe { &mut *sdl_window };
+    let app = unsafe { &mut *app };
+
+    let title = if sdl_window.title.is_null() {
+        None
+    } else {
+        Some(unsafe { CStr::from_ptr(sdl_window.title) })
+    };
+    let w = sdl_window.w;
+    let h = sdl_window.h;
+    let mut builder = WindowBuilder::new(w as u32, h as u32)
+        .use_all_space(false)
+        .x(Some(sdl_window.x as i32))
+        .y(Some(sdl_window.y as i32));
+    if let Some(title) = title.and_then(|t| t.to_str().ok()) {
+        builder = builder.title(title);
+    } else {
+        builder = builder.title(" ");
+    }
+
+    let window = builder.build::<SDLData, (), ()>(());
+    let win_id = app.add_window(window);
+    sdl_window.set_window_data(win_id, 0);
+
+    true
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_destroy_SDL_window(app: *mut SDLApp, sdl_window_ptr: *mut SDLWindow) {
+    let sdl_window = unsafe { &mut *sdl_window_ptr };
+    let app = unsafe { &mut *app };
+    app.with_window_mut(sdl_window.real_win_id(), |window, data| {
+        window.update_ctx(data);
+    });
+    drop(app.remove_window(sdl_window.real_win_id()));
+    eprintln!("Window destroyed: {sdl_window_ptr:?}");
+}
+
+use libopal::window::Pixel;
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_setup_window_pixels(
+    app: *mut SDLApp,
+    sdl_window: *mut SDLWindow,
+    pixels: *mut *mut u8,
+    pitch: *mut c_int,
+) {
+    let sdl_window = unsafe { &mut *sdl_window };
+    let app = unsafe { &mut *app };
+    let pixels = unsafe { &mut *pixels };
+    let pitch = unsafe { &mut *pitch };
+
+    let window = app
+        .get_window(sdl_window.real_win_id())
+        .expect("BAD SDL window");
+    let win_id = window.win_id();
+
+    let (pixels_raw, draw_y_off, _) = window
+        .unoccupied_pixels()
+        .expect("No unoccupied window pixels");
+    sdl_window.set_window_data(win_id, draw_y_off);
+    *pixels = pixels_raw.as_mut_ptr().cast::<u8>();
+    *pitch = (window.inner_mut().width() as usize * size_of::<Pixel>()) as c_int;
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_update_window_pixels(
+    app: *mut SDLApp,
+    sdl_window: *mut SDLWindow,
+    rects: *const SDLRect,
+    num_rects: c_int,
+) {
+    let sdl_window = unsafe { &mut *sdl_window };
+    let app = unsafe { &mut *app };
+
+    let rects = unsafe { std::slice::from_raw_parts(rects, num_rects as usize) };
+    let window = app
+        .get_window(sdl_window.real_win_id())
+        .expect("Bad SDL Window");
+    let draw_y_off = sdl_window.draw_y_off();
+    for rect in rects {
+        window.inner_mut().redraw(
+            rect.x as u32,
+            (rect.y as u32) + draw_y_off,
+            rect.w as u32,
+            rect.h as u32,
+        );
+    }
+}
