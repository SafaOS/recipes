new file mode 100644
index 0000000..240f8c9
--- /dev/null
+++ b/src/timer/safaos/SDL_systimer.c
@@ -0,0 +1,81 @@
+/*
+  Simple DirectMedia Layer
+  Copyright (C) 1997-2026 Sam Lantinga <slouken@libsdl.org>
+
