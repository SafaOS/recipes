--- /dev/null
+++ b/src/main/safaos/SDL_safaos_main.c
@@ -0,0 +1,30 @@
+extern void _salibc_start(void);
+
+#if defined(__x86_64__) || defined(_M_X64)
+__attribute__((naked, noreturn, section(".text._start")))
+void _start(void) {
+    __asm__ volatile (
+        "and  $~0xf, %%rsp\n\t"
+        "push %%rbp\n\t"
+        "push %%rbp\n\t"
+        "call _salibc_start\n\t"
+        "ud2\n\t"
+        ::: "memory"
+    );
+}
+
+#elif defined(__aarch64__) || defined(_M_ARM64)
+__attribute__((naked, noreturn, section(".text._start")))
+void _start(void) {
+    __asm__ volatile (
+        "bic  sp,  sp,  #0xf\n\t"
+        "stp  x29, x29, [sp, #-16]!\n\t"
+        "bl   _salibc_start\n\t"
+        "udf  #0\n\t"
+        ::: "memory"
+    );
+}
+
+#else
+#  error "Unsupported architecture: add a _start for your target in entry.c"
+#endif
