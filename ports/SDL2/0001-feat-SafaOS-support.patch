+use std::{sync::atomic::AtomicU64, thread::sleep, time::Duration};
+
+use safa_api::syscalls::clock;
+
+mod audio;
+mod video;
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_sleep_ms(delay: u64) {
+    sleep(Duration::from_millis(delay));
+}
+
+static CNT_FREQ: AtomicU64 = AtomicU64::new(0);
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_uptime_ms() -> u64 {
+    let mut freq = CNT_FREQ.load(std::sync::atomic::Ordering::Relaxed);
+    if freq == 0 {
+        freq = clock::getcntfreq();
+        CNT_FREQ.store(freq, std::sync::atomic::Ordering::Release);
+    }
+    clock::getcnttime(freq).as_millis() as u64
+}
