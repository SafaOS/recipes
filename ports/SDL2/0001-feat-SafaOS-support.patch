+++ b/sdl-safaos/src/audio.rs
@@ -0,0 +1,59 @@
+use std::ffi::c_int;
+
+use libartemis::{misc::AudioFormat, stream::Stream};
+use safa_api::syscalls::thread::yield_now;
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFAAUD_get_stream_buf(stream: *mut Stream) -> *mut u8 {
+    unsafe { (*stream).buf_mut().as_mut_ptr() }
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFAAUD_stream_sync_all(stream: *mut Stream) -> u32 {
+    let stream = unsafe { &mut *stream };
+    let pending = (stream.buf_mut().len() / stream.bytes_per_sample() as usize) as u32;
+    let mut synced = 0;
+    while pending > synced {
+        let now = stream.sync(synced, pending - synced);
+        if now == 0 {
+            yield_now();
+        }
+
+        synced += now;
+    }
+
+    synced
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_destroy_stream(stream: *mut Stream) {
+    drop(unsafe { Box::from_raw(stream) });
+}
+
+#[unsafe(no_mangle)]
+extern "C" fn SAFA_create_stream(
+    freq: u32,
+    audio_depth: u32,
+    is_floating: bool,
+    is_singed: bool,
+    channels: u16,
+    samples: u32,
+    stream_storage: *mut *mut Stream,
+) -> c_int {
+    let Some(format) = AudioFormat::from_raw(
+        channels as u8,
+        freq,
+        audio_depth as u8,
+        match (is_floating, is_singed) {
+            (true, _) => libartemis::misc::SampleFormat::Floating,
+            (false, true) => libartemis::misc::SampleFormat::Singed,
+            (false, false) => todo!("Unsigned Audio"),
+        },
+    ) else {
+        return -2;
+    };
+
+    let stream = Stream::create(format, samples);
+    unsafe { *stream_storage = Box::into_raw(Box::new(stream)) };
+    0
+}
